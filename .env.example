# === Database máy chấm công (READ-ONLY) ===
ATTENDANCE_DB_SERVER=
ATTENDANCE_DB_PORT=
ATTENDANCE_DB_NAME=
ATTENDANCE_DB_USER=
ATTENDANCE_DB_PASSWORD=

# === Database app - PostgreSQL (AppUsers - READ/WRITE) ===
# Khi chạy Docker: APP_DB_HOST=app-db, APP_DB_PORT=5432 (đã set trong docker-compose)
# Khi chạy local:  APP_DB_HOST=localhost, APP_DB_PORT=45432
APP_DB_HOST=localhost
APP_DB_PORT=45432
APP_DB_NAME=vt_check_attendance
APP_DB_USER=vtadmin
APP_DB_PASSWORD=VtAttendance@2026

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-secret-string
NEXTAUTH_URL=http://localhost:3000

# Default Admin (used during seed — GET /api/seed)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# === Azure AD (OAuth Outlook - gửi email tài khoản) ===
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
